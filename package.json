{
  "name": "turtle-soup-ai",
  "version": "0.1.0",
  "private": true,
  "license": "GPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite --configLoader native",
    "dev:start": "powershell -ExecutionPolicy Bypass -File scripts/start-dev.ps1",
    "dev:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-dev.ps1",
    "build": "tsc -b && vite build --configLoader native",
    "test:api": "node --test api-proxy/index.test.mjs",
    "check:api": "node --check api-proxy/index.mjs && node --check api-proxy/proxy-core.mjs",
    "preview": "vite preview --configLoader native",
    "deploy": "npm run build -- --base=/turtle-soup-ai/ && gh-pages -d dist"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "lucide-react": "^0.544.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "gh-pages": "^6.3.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.7"
  }
}
